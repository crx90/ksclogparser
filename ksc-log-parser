function applyDeathLimit(deaths,limit){return(!limit||limit<=0)?deaths:deaths.slice(0,limit);}

function renderRaidCDOverview(pulls) {
  const el = document.getElementById('an-raid-cd-chart');
  if (!el) return;
  const raidSet = getRaidCDSet();

  // Collect all raidCDs across pulls, filter to known raid CDs
  const allCDs = [];
  for (const p of pulls) {
    if (!p.raidCDs) continue;
    for (const cd of p.raidCDs) {
      if (raidSet.has(cd.spell)) allCDs.push({ ...cd, pull: p });
    }
  }
  if (!allCDs.length) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">&#128737;</div><p>Keine Raid-CDs in den geladenen Pulls</p></div>';
    return;
  }

  // Group by spell
  const bySpell = {};
  for (const cd of allCDs) {
    if (!bySpell[cd.spell]) bySpell[cd.spell] = [];
    bySpell[cd.spell].push(cd);
  }
  const spells = Object.keys(bySpell).sort((a, b) => a.localeCompare(b));

  // Layout: x-axis = pull number, vertical lines per usage within pull
  // Each pull occupies a fixed-width slot; within a slot x = offsetMs ratio
  const SLOT_W = Math.max(20, Math.min(60, Math.floor(720 / Math.max(pulls.length, 1))));
  const PAD_L = 148, PAD_R = 20, PAD_T = 8, PAD_B = 28;
  const ROW_H = 28;
  const W = PAD_L + pulls.length * SLOT_W + PAD_R;
  const H = spells.length * ROW_H + PAD_T + PAD_B;

  let svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" width="100%" style="display:block;background:var(--bg-deep);border-radius:6px">';

  // Pull separators + labels
  pulls.forEach((p, pi) => {
    const slotX = PAD_L + pi * SLOT_W;
    // Separator line
    svg += '<line x1="' + slotX + '" y1="' + PAD_T + '" x2="' + slotX + '" y2="' + (H - PAD_B) + '" stroke="#252b36" stroke-width="0.5"/>';
    // Pull number label on x-axis
    const label = '#' + p.num;
    const col = p.success ? '#27ae60' : '#c0392b';
    svg += '<text x="' + (slotX + SLOT_W / 2) + '" y="' + (H - 8) + '" text-anchor="middle" font-size="8" fill="' + col + '">' + label + '</text>';
    // Kill/wipe indicator bar at bottom
    svg += '<rect x="' + slotX + '" y="' + (H - PAD_B) + '" width="' + SLOT_W + '" height="3" fill="' + col + '" opacity="0.5"/>';
  });
  // Closing separator
  svg += '<line x1="' + (PAD_L + pulls.length * SLOT_W) + '" y1="' + PAD_T + '" x2="' + (PAD_L + pulls.length * SLOT_W) + '" y2="' + (H - PAD_B) + '" stroke="#252b36" stroke-width="0.5"/>';

  // Rows per spell
  spells.forEach((spell, si) => {
    const y = PAD_T + si * ROW_H;
    const midY = y + ROW_H / 2;
    if (si % 2 === 0) svg += '<rect x="' + PAD_L + '" y="' + y + '" width="' + (pulls.length * SLOT_W) + '" height="' + ROW_H + '" fill="rgba(255,255,255,0.015)"/>';

    // Usages
    const usages = bySpell[spell];
    for (const cd of usages) {
      const pi = pulls.indexOf(cd.pull);
      if (pi < 0) continue;
      const pullDur = cd.pull.endTime - cd.pull.startTime;
      const relX = pullDur > 0 ? (cd.offsetMs / pullDur) * SLOT_W : SLOT_W / 2;
      const x = (PAD_L + pi * SLOT_W + Math.min(relX, SLOT_W - 1)).toFixed(1);
      const casterShort = cd.caster ? cd.caster.split('-')[0] : '?';
      svg += '<line x1="' + x + '" y1="' + (y + 3) + '" x2="' + x + '" y2="' + (y + ROW_H - 3) + '" stroke="#c8a84b" stroke-width="2" stroke-linecap="round">';
      svg += '<title>' + escHtml(cd.spell) + '\n' + escHtml(casterShort) + ' @ Pull #' + cd.pull.num + ' ' + formatOffset(cd.offsetMs) + '</title>';
      svg += '</line>';
      // Caster initials if slot wide enough
      if (SLOT_W >= 30) {
        const initials = casterShort.substring(0, SLOT_W >= 50 ? 6 : 3);
        svg += '<text x="' + (+x + 2) + '" y="' + (midY + 3) + '" font-size="7" fill="rgba(200,168,75,0.65)" style="pointer-events:none">' + escHtml(initials) + '</text>';
      }
    }
  });

  svg += '</svg>';

  // HTML labels (wh-spell links)
  const labelDiv = '<div style="position:absolute;left:0;top:0;width:' + PAD_L + 'px;pointer-events:none">'
    + spells.map((spell, si) => {
        const midY = PAD_T + si * ROW_H + ROW_H / 2;
        return '<div style="position:absolute;right:8px;top:' + (midY - 7) + 'px;font-size:11px;text-align:right;line-height:1;pointer-events:auto">'
          + spellLink(spell, 'rcd-spell-link') + '</div>';
      }).join('')
    + '</div>';

  el.innerHTML = '<div style="position:relative">' + labelDiv + svg + '</div>';
  setTimeout(() => enrichSpellLinks(el), 100);
}

function renderAnalysis(pulls,deathLimit=0){
  const effectiveDeaths=pulls.flatMap(p=>applyDeathLimit(p.deaths,deathLimit));
  const kills=pulls.filter(p=>p.success).length;
  const killRate=pulls.length?Math.round(kills/pulls.length*100):0;
  const durations=pulls.filter(p=>p.endTime&&p.startTime).map(p=>p.endTime-p.startTime).filter(d=>d>0);
  const avgDur=durations.length?durations.reduce((a,b)=>a+b,0)/durations.length:0;
  document.getElementById('an-total-pulls').textContent=pulls.length;
  document.getElementById('an-kills').textContent=kills;
  document.getElementById('an-kill-rate').textContent='Kill-Rate '+killRate+'%';
  document.getElementById('an-avg-duration').textContent=formatDuration(avgDur);
  document.getElementById('an-total-deaths').textContent=effectiveDeaths.length;
  document.getElementById('an-deaths-per-pull').textContent=pulls.length?'&#216; '+(effectiveDeaths.length/pulls.length).toFixed(1)+' / Pull':'&#216; -- / Pull';
  document.getElementById('an-date-range').textContent=analysisFileMeta.length+' Datei(en)'+(deathLimit?', &#8804;'+deathLimit+' Tode':'');

  // Deaths by player — store name as data attribute, no inline JS with name
  const byPlayer={};
  for(const d of effectiveDeaths) byPlayer[d.name]=(byPlayer[d.name]||0)+1;
  const pSorted=Object.entries(byPlayer).sort((a,b)=>b[1]-a[1]).slice(0,12);
  const maxP=pSorted[0]?.[1]||1;
  const playerEl=document.getElementById('an-deaths-by-player');
  playerEl.innerHTML=pSorted.length
    ?pSorted.map(([n,c],i)=>'<div class="bar-row player-bar'+(selectedPlayer===n?' active':'')+'" data-player-idx="'+i+'" title="Klick: Todesursachen filtern"><div class="bar-label">'+escHtml(n)+'</div><div class="bar-track"><div class="bar-fill red" style="width:'+Math.max(8,c/maxP*100)+'%">'+c+'</div></div></div>').join('')
    :'<div class="empty"><div class="empty-icon">&#128737;</div><p>Keine Tode</p></div>';
  // Store player names in array for click handler
  window._playerNames = pSorted.map(([n])=>n);
  playerEl.querySelectorAll('.player-bar').forEach(el=>{
    el.onclick=()=>{ filterByPlayer(window._playerNames[+el.dataset.playerIdx]); };
  });

  // Death causes — filter by selected player
  const causesSource=selectedPlayer?effectiveDeaths.filter(d=>d.name===selectedPlayer):effectiveDeaths;
  const causeTitle=document.getElementById('an-death-causes-title');
  if(causeTitle){
    if(selectedPlayer){
      causeTitle.textContent='';
      causeTitle.innerHTML='&#9888; Todesursachen &#8212; '+escHtml(selectedPlayer)+' ';
      const x=document.createElement('span');
      x.textContent='&#10005; Filter aufheben';
      x.style.cssText='font-weight:400;cursor:pointer;color:var(--text-dim);font-size:10px;text-transform:none;letter-spacing:0';
      x.onclick=clearPlayerFilter;
      causeTitle.appendChild(x);
    } else {
      causeTitle.textContent='&#9888; Häufigste Todesursachen';
    }
  }
  // Aggregate: cause name → {count, causeId (first seen)}
  const byCause={};
  for(const d of causesSource) {
    const k=d.cause||'Unbekannt';
    if(!byCause[k]) byCause[k]={count:0,causeId:d.causeId||null};
    byCause[k].count++;
    if(!byCause[k].causeId && d.causeId) byCause[k].causeId=d.causeId;
  }
  const cSorted=Object.entries(byCause).sort((a,b)=>b[1].count-a[1].count).slice(0,12);
  const maxC=cSorted[0]?.[1].count||1;
  document.getElementById('an-death-causes').innerHTML=cSorted.length
    ?cSorted.map(([c,{count:n,causeId:cid}])=>'<div class="bar-row"><div class="bar-label">'+spellLink(c,'cause-link',cid)+'</div><div class="bar-track"><div class="bar-fill gold" style="width:'+Math.max(8,n/maxC*100)+'%">'+n+'</div></div></div>').join('')
    :'<div class="empty"><div class="empty-icon">&#9888;</div><p>Keine Todesursachen</p></div>';
  setTimeout(() => enrichSpellLinks(document.getElementById('an-death-causes')), 100);

  // Duration chart — clickable bars, skull marker if selectedPlayer died
  const chartEl=document.getElementById('an-duration-chart');
  if(pulls.length&&durations.length){
    const maxDur=Math.max(...durations);
    const w=Math.max(4,Math.min(26,Math.floor(900/pulls.length)));
    // Wrap each bar in a relative div so we can overlay the skull
    const bars = pulls.map(p=>{
      const dur=p.endTime&&p.startTime?p.endTime-p.startTime:0;
      const h=dur?Math.max(4,Math.round(dur/maxDur*72)):4;
      const col=p.success?'var(--green)':'var(--red)';
      const isSelected = p.num === selectedPullNum;
      // Check if selectedPlayer died in this pull (respecting death limit)
      const playerDied = selectedPlayer
        ? applyDeathLimit(p.deaths, deathLimit).some(d=>d.name===selectedPlayer)
        : false;
      // Skull + orange overlay when player died
      const skullOverlay = playerDied
        ? '<div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:10px;line-height:1">&#128128;</div>'
          + '<div style="position:absolute;inset:0;background:rgba(255,140,0,0.35);border-radius:2px 2px 0 0;pointer-events:none"></div>'
        : '';
      const title='Pull #'+p.num+': '+escHtml(p.bossName)+'&#10;'+formatDuration(dur)+' · '+(p.success?'Kill':'Wipe')+(playerDied?' · '+escHtml(selectedPlayer)+' gestorben':'');
      const selRing = isSelected ? 'outline:2px solid var(--gold);outline-offset:1px;z-index:2;' : '';
      const selTag = isSelected ? '<div style="position:absolute;bottom:100%;left:50%;transform:translateX(-50%);font-size:8px;color:var(--gold);white-space:nowrap;margin-bottom:1px;pointer-events:none;font-family:var(--font-mono)">▼</div>' : '';
      return '<div style="position:relative;flex-shrink:0;width:'+w+'px;display:flex;align-items:flex-end">'
        + '<div data-pull-num="'+p.num+'" title="'+title+'" style="width:100%;height:'+h+'px;background:'+col+';border-radius:2px 2px 0 0;cursor:pointer;opacity:'+(isSelected?'1':'0.75')+';transition:opacity .1s;position:relative;'+selRing+'" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='+(isSelected?'1':'0.75')+'" >' + selTag
        + skullOverlay
        + '</div></div>';
    });
    chartEl.innerHTML='<div style="display:flex;align-items:flex-end;gap:2px;height:94px;overflow-x:auto;padding-bottom:4px;padding-top:14px">'+bars.join('')+'</div>'
      +'<div style="font-size:11px;color:var(--text-dim);margin-top:6px">&#128994; Kill &nbsp; &#128308; Wipe'
      +(selectedPlayer?' &nbsp;&#183;&nbsp; &#128128; = <strong style="color:var(--gold)">'+escHtml(selectedPlayer)+'</strong> gestorben':'')
      +' &nbsp;&#183;&nbsp; Klick auf Balken = Detail</div>';
    chartEl.querySelectorAll('[data-pull-num]').forEach(el=>{
      el.onclick=()=>showPullDetail(+el.dataset.pullNum);
    });
  } else {
    chartEl.innerHTML='<div class="empty"><div class="empty-icon">&#128200;</div><p>Keine Pulls geladen</p></div>';
  }

  // Pull table
  const tableEl=document.getElementById('an-pulls-table');
  if(pulls.length){
    tableEl.innerHTML=[...pulls].reverse().map(p=>'<div class="pull-row'+(selectedPullNum===p.num?' selected':'')+'" onclick="showPullDetail('+p.num+')"><span class="pull-num">#'+p.num+'</span><span class="pull-boss">'+escHtml(p.bossName)+'</span><span class="pull-duration">'+formatDuration(p.endTime-p.startTime)+'</span><span class="pull-deaths '+(p.deaths.length?'has-deaths':'no-deaths')+'">'+(p.deaths.length?'&#128128; '+p.deaths.length:'&#9989; 0')+'</span><span>'+(p.success?'<span class="badge badge-kill">Kill</span>':'<span class="badge badge-wipe">Wipe</span>')+'</span></div>').join('');
  } else {
    tableEl.innerHTML='<div class="empty"><p>Keine Pulls</p></div>';
  }
}

let _currentFilteredPulls = []; // keeps track of the filtered list for prev/next nav

function navigatePull(dir) {
  if (!_currentFilteredPulls.length || selectedPullNum === null) return;
  const idx = _currentFilteredPulls.findIndex(p => p.num === selectedPullNum);
  if (idx === -1) return;
  const next = _currentFilteredPulls[idx + dir];
  if (next) showPullDetail(next.num);
}

function showPullDetail(num) {
  if(selectedPullNum===num){
    selectedPullNum=null;
    document.getElementById('an-pull-detail').style.display='none';
    const ov=document.getElementById('an-raid-cd-overview');if(ov)ov.style.display='none';
    filterBoss(); return;
  }
  selectedPullNum=num; selectedDeathIdx=null;
  const pull=analysisPulls.find(p=>p.num===num);
  const detailEl=document.getElementById('an-pull-detail');
  if(!pull){detailEl.style.display='none';return;}
  const deathLimit=parseInt(document.getElementById('death-limit').value)||0;
  const visDeaths=applyDeathLimit(pull.deaths,deathLimit);
  detailEl.style.display='block';
  detailEl.innerHTML=buildPullDetailHTML(pull,visDeaths,'showDeathContext');
  
  setTimeout(() => enrichSpellLinks(detailEl), 100);
  detailEl.scrollIntoView({behavior:'smooth',block:'nearest'});

  // Standalone Raid CD panel
  const raidSet=getRaidCDSet();
  const hasCDs=pull.raidCDs&&pull.raidCDs.some(cd=>raidSet.has(cd.spell));
  const overviewEl=document.getElementById('an-raid-cd-overview');
  const contentEl=document.getElementById('an-raid-cd-content');
  const titleEl=document.getElementById('an-raid-cd-title');
  if(overviewEl){
    if(hasCDs){
      overviewEl.style.display='block';
      // Nav arrows on the raid CD panel
      const curIdxN = _currentFilteredPulls.findIndex(p=>p.num===pull.num);
      const prevP = _currentFilteredPulls[curIdxN-1];
      const nextP = _currentFilteredPulls[curIdxN+1];
      const titleText = 'Pull #'+pull.num+' · '+pull.bossName+' · '+formatDuration(pull.endTime-pull.startTime);
      if(titleEl) titleEl.textContent = titleText;
      // Update nav buttons on the card edges
      const prevBtn = document.getElementById('an-nav-prev');
      const nextBtn = document.getElementById('an-nav-next');
      if(prevBtn){ prevBtn.style.display = prevP ? '' : 'none'; prevBtn.title = prevP ? '← Pull #'+prevP.num : ''; }
      if(nextBtn){ nextBtn.style.display = nextP ? '' : 'none'; nextBtn.title = nextP ? '→ Pull #'+nextP.num : ''; }
      contentEl.innerHTML=buildRaidCDHTML(pull)||'<div class="empty"><p>Keine Raid-CDs</p></div>';
      setTimeout(()=>enrichSpellLinks(contentEl),100);
    } else {
      overviewEl.style.display='none';
      const pb=document.getElementById('an-nav-prev'); if(pb) pb.style.display='none';
      const nb=document.getElementById('an-nav-next'); if(nb) nb.style.display='none';
    }
  }
  filterBoss();
}
