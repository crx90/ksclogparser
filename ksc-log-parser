    playerSel.innerHTML = '<option value="">— Spieler wählen —</option>'
      + [...players].sort().map(p=>`<option value="${escHtml(p)}"${aplSelectedPlayer===p?' selected':''}>${escHtml(p)}</option>`).join('');
  }

  const pullSel = document.getElementById('apl-pull-select');
  if (pullSel) {
    pullSel.innerHTML = '<option value="">— Pull wählen —</option>'
      + [...analysisPulls].reverse().map(p=>`<option value="${p.num}"${aplSelectedPull===p.num?' selected':''}>#${p.num} ${escHtml(p.bossName)} (${formatDuration(p.endTime-p.startTime)}) ${p.success?'[Kill]':'[Wipe]'}</option>`).join('');
  }

  const specSel = document.getElementById('apl-spec-select');
  if (specSel && specSel.options.length <= 1) {
    specSel.innerHTML = '<option value="">— Spec wählen —</option>'
      + Object.keys(APL_SPECS).map(s=>`<option value="${s}">${s}</option>`).join('');
  }

  renderAPLResult();
}

function renderAPLResult() {
  const el = document.getElementById('apl-result');
  if (!el) return;

  if (!aplRawText) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">📋</div><p>Lade eine APL von GitHub oder lade eine .simc Datei hoch.</p></div>';
    return;
  }
  if (!aplSelectedPlayer || aplSelectedPull === null) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">👤</div><p>Wähle Spieler und Pull, dann klick "Analyse starten".</p></div>';
    return;
  }

  const pull = analysisPulls.find(p=>p.num===aplSelectedPull);
  if (!pull) { el.innerHTML = '<div class="empty"><p>Pull nicht gefunden.</p></div>'; return; }

  const playerNorm = normalizeForMatch(aplSelectedPlayer);
  const pullDurMs = pull.endTime - pull.startTime;

  // Player casts for this pull
  const casts = (pull.playerCasts||[])
    .filter(c => normalizeForMatch(c.playerName.split('-')[0]) === playerNorm)
    .sort((a,b) => a.offsetMs - b.offsetMs);

  if (!casts.length) {
    el.innerHTML = `<div class="empty"><div class="empty-icon">🔍</div><p>Keine Casts für <strong>${escHtml(aplSelectedPlayer)}</strong> in Pull #${pull.num} gefunden.<br><span style="font-size:11px;color:var(--text-dim)">Hinweis: Casts werden aus SPELL_CAST_SUCCESS Events gelesen. Stelle sicher dass Advanced Logging aktiviert ist.</span></p></div>`;
    return;
  }

  // Build APL spell set for quick lookup
  const aplSpellNorms = new Set();
  const aplActionsBefore = {}; // normName → list of higher-prio actions
  if (aplParsed) {
    for (const [lname, actions] of Object.entries(aplParsed.lists)) {
      actions.forEach((a,i) => {
        if (!a.displayName) return;
        const norm = normalizeForMatch(a.displayName);
        aplSpellNorms.add(norm);
        aplSpellNorms.add(normalizeForMatch(a.spell));
        // Store what comes before it in priority
        if (!aplActionsBefore[norm]) aplActionsBefore[norm] = [];
        aplActionsBefore[norm] = actions.slice(0,i).filter(x=>x.displayName&&!['call_action_list','run_action_list','auto_attack','use_items','use_item','potion','variable'].includes(x.spell));
      });
    }
  }

  // Analyse casts
  const analysedCasts = casts.map(cast => {
    const castNorm = normalizeForMatch(cast.spell);
    const inAPL = aplSpellNorms.has(castNorm);
    const buffs = buildBuffStateAtTime(pull, aplSelectedPlayer, pull.startTime + cast.offsetMs);
    const runicPower = cast.runicPower;
    const suggestions = inAPL && aplParsed
      ? evaluateAPLAtCast(cast, buffs, runicPower, aplParsed, pullDurMs)
      : [];
    return { cast, inAPL, buffs, suggestions };
  });

  const withViolations = analysedCasts.filter(c=>c.suggestions.length>0);
  const inAPLCount = analysedCasts.filter(c=>c.inAPL).length;
  const violationCount = withViolations.length;

  let html = `
  <div class="grid-4 section" style="gap:14px;margin-bottom:20px">
    <div class="stat-box"><div class="stat-label">Casts gesamt</div><div class="stat-value gold">${casts.length}</div><div class="stat-sub">${escHtml(aplSelectedPlayer)}</div></div>
    <div class="stat-box"><div class="stat-label">In APL erkannt</div><div class="stat-value green">${inAPLCount}</div><div class="stat-sub">${Math.round(inAPLCount/casts.length*100)}% Abdeckung</div></div>
    <div class="stat-box"><div class="stat-label">Mögliche Violations</div><div class="stat-value ${violationCount>0?'red':'green'}">${violationCount}</div><div class="stat-sub">APL-Abweichungen</div></div>
    <div class="stat-box"><div class="stat-label">APL Zeilen</div><div class="stat-value">${Object.values(aplParsed?.lists||{}).flat().length}</div><div class="stat-sub">Aktionen total</div></div>
  </div>`;

  // Violations panel
  if (violationCount > 0) {
    html += `<div class="card section" style="border-color:rgba(192,57,43,0.4)">
      <div class="card-title" style="color:var(--red)">⚠️ APL-Abweichungen (${violationCount})</div>
      <div class="scroll-area" style="max-height:300px">`;
    for (const {cast, suggestions} of withViolations) {
      html += `<div style="padding:8px;border-bottom:1px solid var(--border);display:flex;gap:12px;align-items:flex-start">
        <div style="flex-shrink:0;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);padding-top:2px">${formatDuration(cast.offsetMs)}</div>
        <div>
          <div style="font-size:13px;margin-bottom:4px">Gecastet: ${spellLink(cast.spell,'',cast.spellId)}</div>
          ${suggestions.map(s=>`<div style="font-size:11px;color:var(--red);margin-top:2px">
            ↑ Prio ${s.priority+1}: ${spellLink(s.spell,'')}
            ${s.condition?`<span style="color:var(--text-dim);font-size:10px"> (${escHtml(s.condition.substring(0,60)+(s.condition.length>60?'…':''))})</span>`:''}
          </div>`).join('')}
        </div>
      </div>`;
    }
    html += `</div></div>`;
  } else if (aplParsed) {
    html += `<div class="card section" style="border-color:rgba(39,174,96,0.3)"><div style="padding:8px;color:var(--green);font-size:13px">✅ Keine erkennbaren APL-Abweichungen in diesem Pull.</div></div>`;
  }

  // Full cast timeline
  html += `<div class="card section">
    <div class="card-title">⚔️ Cast-Timeline — ${escHtml(aplSelectedPlayer)}</div>
    <div style="font-family:var(--font-mono);font-size:11px;max-height:400px;overflow-y:auto">
      <div style="display:grid;grid-template-columns:60px 1fr 60px;gap:8px;padding:4px 6px;color:var(--text-dim);font-size:10px;border-bottom:1px solid var(--border);margin-bottom:4px">
        <span>Zeit</span><span>Spell</span><span style="text-align:right">APL</span>
      </div>
      ${analysedCasts.map(({cast,inAPL,suggestions})=>{
        const hasViol = suggestions.length > 0;
        const bg = hasViol ? 'rgba(192,57,43,0.08)' : '';
        return `<div style="display:grid;grid-template-columns:60px 1fr 60px;gap:8px;padding:4px 6px;border-radius:4px;background:${bg}">
          <span style="color:var(--text-dim)">${formatDuration(cast.offsetMs)}</span>
          <span>${spellLink(cast.spell,'',cast.spellId)}</span>
          <span style="text-align:right;color:${inAPL?(hasViol?'var(--red)':'var(--green)'):'var(--text-dim)'}">${inAPL?(hasViol?'⚠️':'✓'):'—'}</span>
        </div>`;
      }).join('')}
    </div>
  </div>`;

  // APL viewer with usage highlights
  if (aplParsed) {
    const usedNorms = new Set(casts.map(c=>normalizeForMatch(c.spell)));
    html += `<div class="card section">
      <div class="card-title">📋 APL — ${aplParsed.specName||'Geladen'}</div>
      <div style="font-size:10px;color:var(--text-dim);margin-bottom:8px">🟡 = in diesem Pull gecastet &nbsp; 🔵 = in APL, nicht gecastet</div>
      <div style="font-family:var(--font-mono);font-size:11px;max-height:400px;overflow-y:auto;background:var(--bg-deep);border-radius:6px;padding:10px;line-height:1.9">
        ${Object.entries(aplParsed.lists).map(([lname,actions])=>{
          const dname = lname==='__main__'?'actions':'actions.'+lname;
          return `<div style="margin-bottom:14px">
            <div style="color:var(--gold);font-weight:600;margin-bottom:4px">${escHtml(dname)}</div>
            ${actions.map((a,i)=>{
              const dn = a.displayName || a.spell;
              const dnNorm = normalizeForMatch(dn);
              const snorm = normalizeForMatch(a.spell);
              const used = usedNorms.has(dnNorm)||usedNorms.has(snorm);
              const isMeta = ['call_action_list','run_action_list','auto_attack','use_items','use_item','potion','variable','snapshot_stats'].includes(a.spell);
              const col = isMeta?'var(--text-dim)':used?'var(--gold)':'#5a7a9a';
              const dot = isMeta?'':used?'🟡 ':'🔵 ';
              return `<div style="padding:1px 4px;border-radius:3px">
                <span style="color:var(--text-dim);margin-right:6px;font-size:10px">${String(i+1).padStart(2,' ')}.</span>
                <span style="color:${col}">${dot}${escHtml(dn)}</span>
                ${a.ifCond?`<span style="color:var(--text-dim);font-size:10px">,if=</span><span style="color:#4a6a7a;font-size:10px">${escHtml(a.ifCond.substring(0,60)+(a.ifCond.length>60?'…':''))}</span>`:''}
              </div>`;
            }).join('')}
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }

  el.innerHTML = html;
  setTimeout(() => enrichSpellLinks(el), 100);
}

async function aplLoadFromGitHub() {
  const spec = document.getElementById('apl-spec-select').value;
  if (!spec) return;
  const filename = APL_SPECS[spec];
  if (!filename) return;
  const statusEl = document.getElementById('apl-load-status');
  const previewEl = document.getElementById('apl-raw-preview');
  statusEl.textContent = 'Lade von GitHub…';
  statusEl.style.color = 'var(--text-sec)';
  try {
    const url = APL_GITHUB_BASE + filename + '.simc';
    const r = await fetch(url);
    if (!r.ok) throw new Error(`HTTP ${r.status} — Datei nicht gefunden für: ${filename}`);
    aplRawText = await r.text();
    aplParsed = parseAPL(aplRawText);
    aplParsed.specName = spec;
    const lineCount = Object.values(aplParsed.lists).flat().length;
    statusEl.textContent = `✓ ${spec} — ${lineCount} APL-Aktionen geladen`;
    statusEl.style.color = 'var(--green)';
    previewEl.style.display = 'block';
    previewEl.textContent = aplRawText.split('\n').filter(l=>!l.startsWith('#')).slice(0,20).join('\n')+'…';
    renderAPLResult();
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.style.color = 'var(--red)';
  }
}

function aplLoadFromFile(evt) {
  const file = evt.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    aplRawText = e.target.result;
    aplParsed = parseAPL(aplRawText);
    aplParsed.specName = file.name.replace('.simc','');
    const statusEl = document.getElementById('apl-load-status');
    const previewEl = document.getElementById('apl-raw-preview');
    statusEl.textContent = `✓ ${file.name} — ${Object.values(aplParsed.lists).flat().length} APL-Aktionen`;
    statusEl.style.color = 'var(--green)';
    previewEl.style.display = 'block';
    previewEl.textContent = aplRawText.split('\n').filter(l=>!l.startsWith('#')).slice(0,20).join('\n')+'…';
    renderAPLResult();
  };
  reader.readAsText(file);
  evt.target.value = '';
}

