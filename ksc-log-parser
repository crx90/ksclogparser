// ── SimC spell_name → WoW display name (and vice versa) ──────────
// SimC uses snake_case; logs use "Title Case" display names
// We normalize both sides to match them reliably.

function simcToDisplayName(s) {
  // death_strike → Death Strike
  // blood_and_decay → Blood and Decay
  // any_dnd → Death and Decay (class alias)
  const ALIASES = {
    'any_dnd': 'Death and Decay', 'all_dnd': 'Death and Decay',
    'dnd_any': 'Death and Decay', 'wound_spender': 'Scourge Strike',
    'call_action_list': null, 'run_action_list': null,
    'auto_attack': null, 'use_items': null, 'use_item': null,
    'potion': null, 'raise_dead': 'Raise Dead',
    'snapshot_stats': null, 'variable': null, 'arcane_torrent': 'Arcane Torrent',
    'fireblood': 'Fireblood', 'blood_fury': 'Blood Fury',
    'berserking': 'Berserking', 'ancestral_call': 'Ancestral Call',
  };
  if (ALIASES.hasOwnProperty(s)) return ALIASES[s];
  return s.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

function normalizeForMatch(s) {
  return String(s||'').toLowerCase().replace(/[^a-z0-9]/g,'');
}

