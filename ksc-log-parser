<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script>var whTooltips={colorLinks:false,iconizeLinks:false,renameLinks:false,hide:{needed:true}};</script>
<script src="https://wow.zamimg.com/js/tooltips.js"></script>
<title>WoW Combat Log Parser</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');
:root{
  --bg-deep:#0a0b0d;--bg-panel:#111318;--bg-card:#171b22;--bg-hover:#1e232d;
  --border:#252b36;--border-lit:#3a4455;
  --gold:#c8a84b;--gold-dim:#7a6228;--gold-glow:rgba(200,168,75,0.12);
  --red:#c0392b;--red-dim:rgba(192,57,43,0.18);
  --green:#27ae60;--green-dim:rgba(39,174,96,0.18);
  --blue:#2980b9;--blue-dim:rgba(41,128,185,0.18);
  --text-pri:#e8e0d0;--text-sec:#8a9ab5;--text-dim:#4a5568;
  --font-ui:'Inter',system-ui,sans-serif;--font-mono:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg-deep);color:var(--text-pri);font-family:var(--font-ui);font-size:14px;min-height:100vh;line-height:1.5}
header{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;background:var(--bg-panel);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--gold-dim),var(--gold));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:16px}
.logo-text{font-size:16px;font-weight:600;letter-spacing:.04em;color:var(--gold)}
.logo-sub{font-size:11px;color:var(--text-sec);letter-spacing:.08em;text-transform:uppercase}
.tabs{display:flex;gap:2px;background:var(--bg-deep);border-radius:8px;padding:3px}
.tab-btn{padding:7px 16px;border:none;border-radius:6px;background:transparent;color:var(--text-sec);font-family:var(--font-ui);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s}
.tab-btn:hover{background:var(--bg-hover);color:var(--text-pri)}
.tab-btn.active{background:var(--gold-glow);color:var(--gold);border:1px solid var(--gold-dim)}
main{padding:24px;max-width:1400px;margin:0 auto}
.view{display:none}.view.active{display:block}
.progress-wrap{background:var(--bg-panel);border:1px solid var(--border);border-radius:10px;padding:18px 22px;margin-bottom:20px}
.progress-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.progress-label{font-size:13px;color:var(--text-sec)}
.progress-pct{font-family:var(--font-mono);font-size:13px;color:var(--gold)}
.progress-bar-track{height:5px;background:var(--bg-deep);border-radius:3px;overflow:hidden}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold-dim),var(--gold));border-radius:3px;transition:width .3s}
.progress-stats{margin-top:8px;font-size:11px;color:var(--text-dim)}
.btn{display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:7px;border:1px solid var(--border-lit);background:var(--bg-card);color:var(--text-pri);font-family:var(--font-ui);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s}
.btn:hover{background:var(--bg-hover);border-color:var(--gold-dim);color:var(--gold)}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-primary{background:var(--gold-glow);border-color:var(--gold-dim);color:var(--gold)}
.btn-primary:hover{background:rgba(200,168,75,.22);border-color:var(--gold)}
.btn-danger{border-color:#5a2020;color:var(--red)}
.btn-danger:hover{background:var(--red-dim);border-color:var(--red)}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.card{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:16px}
.card-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-sec);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.card-title::after{content:'';flex:1;height:1px;background:var(--border)}
.stat-box{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:14px 18px}
.stat-label{font-size:11px;color:var(--text-sec);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.stat-value{font-size:26px;font-weight:600;color:var(--text-pri);font-variant-numeric:tabular-nums;line-height:1}
.stat-value.gold{color:var(--gold)}.stat-value.red{color:var(--red)}.stat-value.green{color:var(--green)}
.stat-sub{font-size:11px;color:var(--text-dim);margin-top:3px}
.death-entry{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:6px;border:1px solid transparent;margin-bottom:4px}
.death-entry.clickable{cursor:pointer}
.death-entry.clickable:hover{background:var(--bg-hover);border-color:var(--border)}
.death-entry.selected{background:var(--gold-glow);border-color:var(--gold-dim)}
.death-name{font-weight:500;font-size:13px;flex:1}
.death-time{font-family:var(--font-mono);font-size:12px;color:var(--text-sec);white-space:nowrap}
.death-cause{font-size:12px;color:var(--red);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pull-row{display:grid;grid-template-columns:44px 1fr 90px 80px 80px;gap:10px;padding:8px 10px;border-radius:6px;align-items:center;transition:background .1s;cursor:pointer}
.pull-row:hover{background:var(--bg-hover)}
.pull-row.selected{background:var(--gold-glow)}
.pull-row-header{font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;padding-bottom:6px;border-bottom:1px solid var(--border);margin-bottom:2px;cursor:default}
.pull-row-header:hover{background:transparent}
.pull-num{font-family:var(--font-mono);font-size:12px;color:var(--text-dim)}
.pull-boss{font-weight:500;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pull-duration{font-family:var(--font-mono);font-size:12px;color:var(--text-sec)}
.pull-deaths{display:flex;align-items:center;gap:4px;font-family:var(--font-mono);font-size:12px;font-weight:500}
.pull-deaths.has-deaths{color:var(--red)}.pull-deaths.no-deaths{color:var(--green)}
.badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.badge-wipe{background:var(--red-dim);color:var(--red);border:1px solid #5a1515}
.badge-kill{background:var(--green-dim);color:var(--green);border:1px solid #1a5a30}
.badge-active{background:var(--blue-dim);color:var(--blue);border:1px solid #1a3a5a;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
.live-indicator{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;color:var(--green)}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite}
.timeline{position:relative;padding-left:20px}
.timeline::before{content:'';position:absolute;left:6px;top:0;bottom:0;width:1px;background:var(--border)}
.timeline-event{position:relative;padding:6px 0 6px 16px}
.timeline-event::before{content:'';position:absolute;left:-14px;top:12px;width:8px;height:8px;border-radius:50%;background:var(--red);border:2px solid var(--bg-card)}
.timeline-event.start::before{background:var(--green)}
.timeline-event.end-kill::before{background:var(--gold)}
.timeline-event.end-wipe::before{background:var(--red)}
.timeline-time{font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:1px}
.timeline-text{font-size:12px;color:var(--text-pri)}
.timeline-detail{font-size:11px;color:var(--text-sec)}
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;border-radius:5px;padding:2px 3px;transition:background .1s}
.bar-row.player-bar{cursor:pointer}
.bar-row.player-bar:hover{background:var(--bg-hover)}
.bar-row.player-bar.active{background:var(--gold-glow);outline:1px solid var(--gold-dim)}
.bar-label{width:150px;font-size:12px;color:var(--text-sec);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex-shrink:0;transition:color .1s}
.bar-row.player-bar.active .bar-label{color:var(--gold)}
.bar-track{flex:1;height:20px;background:var(--bg-deep);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;display:flex;align-items:center;padding-left:8px;font-size:11px;font-weight:600;font-family:var(--font-mono);min-width:24px}
.bar-fill.red{background:linear-gradient(90deg,#5a1515,#c0392b);color:#ffaaaa}
.bar-fill.gold{background:linear-gradient(90deg,#5a4010,var(--gold));color:#fff8e0}
.empty{padding:32px;text-align:center;color:var(--text-dim)}
.empty-icon{font-size:28px;margin-bottom:8px}
.empty p{font-size:13px}
.file-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
.file-chip{display:flex;align-items:center;gap:6px;padding:4px 10px;background:var(--bg-card);border:1px solid var(--border-lit);border-radius:6px;font-size:12px;color:var(--text-sec)}
.chip-remove{cursor:pointer;color:var(--text-dim);margin-left:2px}
.chip-remove:hover{color:var(--red)}
.boss-select,.num-input,.text-input{background:var(--bg-card);border:1px solid var(--border-lit);border-radius:7px;color:var(--text-pri);font-family:var(--font-ui);font-size:13px;padding:7px 11px;cursor:pointer;outline:none}
.boss-select:focus,.num-input:focus,.text-input:focus{border-color:var(--gold-dim)}
.boss-select{min-width:200px}
.num-input{width:70px;font-family:var(--font-mono)}
.text-input{width:100%}
label.ctrl-label{font-size:12px;color:var(--text-sec)}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg-deep)}
::-webkit-scrollbar-thumb{background:var(--border-lit);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--gold-dim)}
.scroll-area{overflow-y:auto;max-height:400px;padding-right:4px}
.section{margin-bottom:22px}
.flex-gap{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.divider{border:none;border-top:1px solid var(--border);margin:20px 0}
input[type=file]{display:none}
.detail-panel{background:var(--bg-card);border:1px solid var(--border-lit);border-radius:10px;padding:16px;margin-top:14px;position:relative}
.pull-nav-btn{position:absolute;top:50%;transform:translateY(-50%);width:34px;height:34px;border-radius:50%;border:1px solid var(--border-lit);background:var(--bg-panel);color:var(--text-sec);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;z-index:20;line-height:1;padding:0}
.pull-nav-btn:hover{background:var(--gold-glow);border-color:var(--gold-dim);color:var(--gold)}
.pull-nav-btn.prev{left:-17px}
.pull-nav-btn.next{right:-17px}
.pull-nav-btn:disabled{opacity:.25;cursor:not-allowed}
.pull-nav-btn:disabled:hover{background:var(--bg-panel);border-color:var(--border-lit);color:var(--text-sec)}
/* Death context */
.ctx-log{font-family:var(--font-mono);font-size:11px;line-height:1.7;max-height:260px;overflow-y:auto;background:var(--bg-deep);border-radius:6px;padding:8px 10px}
.ctx-row{display:grid;grid-template-columns:52px 46px 1fr 72px;gap:8px;padding:2px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.ctx-row:last-child{border-bottom:none}
.ctx-row.is-death{background:rgba(192,57,43,.15);border-radius:4px;padding:3px 4px;margin:2px -4px}
.ctx-hoverable{border-radius:3px;transition:background .05s}
.ctx-hover-hl{background:rgba(200,168,75,.18) !important;outline:1px solid rgba(200,168,75,.35)}
.ctx-time{color:var(--text-dim)}
.ctx-type-dmg{color:#e05050}.ctx-type-heal{color:#50c050}.ctx-type-death{color:var(--red);font-weight:600}
.ctx-spell{color:var(--text-sec);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ctx-amount-dmg{color:#e05050;text-align:right}.ctx-amount-heal{color:#50c050;text-align:right}
/* Settings */
.settings-section{margin-bottom:24px}
.settings-section h3{font-size:13px;font-weight:600;color:var(--text-sec);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.cd-list{display:flex;flex-direction:column;gap:6px}
.cd-item{display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg-panel);border:1px solid var(--border);border-radius:8px}
.cd-item-name{flex:1;font-size:13px;color:var(--text-pri)}
.cd-item-cat{font-size:11px;padding:2px 8px;border-radius:4px;font-weight:600}
.cd-item-cat.major{background:rgba(200,168,75,.15);color:var(--gold)}
.cd-item-cat.minor{background:rgba(41,128,185,.15);color:var(--blue)}
.cd-item-cat.consumable{background:rgba(80,200,120,.15);color:#50c878}
.cd-item-remove{cursor:pointer;color:var(--text-dim);font-size:16px;line-height:1}
.cd-item-remove:hover{color:var(--red)}
.add-cd-row{display:flex;gap:8px;margin-top:10px}
.cat-select{background:var(--bg-card);border:1px solid var(--border-lit);border-radius:7px;color:var(--text-pri);font-family:var(--font-ui);font-size:12px;padding:7px 10px;outline:none}
@media(max-width:900px){.grid-4{grid-template-columns:1fr 1fr}.grid-2{grid-template-columns:1fr}}
/* Wowhead spell links */
a.wh-spell{color:inherit;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,0.2);cursor:pointer;transition:color .1s}
a.wh-spell:hover{color:var(--gold);border-bottom-color:var(--gold)}
a.wh-spell.ctx-spell-link{color:inherit}
a.wh-spell.ctx-spell-link:hover{color:var(--gold)}
a.wh-spell.cause-link{color:var(--text-sec);border-bottom:none}
a.wh-spell.rcd-invisible-link{font-size:0;width:1px;height:16px;display:inline-block;border-bottom:none;overflow:visible}
a.wh-spell.cause-link:hover{color:var(--gold)}
.death-cause a.wh-spell{color:var(--red);border-bottom:none}
.death-cause a.wh-spell:hover{color:#e05050}
</style>
</head>
<body>
<header>
  <div class="logo">
    <div class="logo-icon">&#9876;</div>
    <div>
      <div class="logo-text">COMBATLOG PARSER</div>
      <div class="logo-sub">WoW Retail &middot; Streaming</div>
    </div>
  </div>
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('live')">&#9889; Live</button>
    <button class="tab-btn" onclick="switchTab('analysis')">&#128202; Analyse</button>
    <button class="tab-btn" onclick="switchTab('apl')">&#127919; APL Analyse</button>
    <button class="tab-btn" onclick="switchTab('settings')">&#9881; Einstellungen</button>
  </div>
</header>
<main>

<!-- LIVE -->
<div id="view-live" class="view active">
  <div class="section">
    <div class="flex-gap" style="margin-bottom:14px">
      <button class="btn btn-primary" id="live-open-btn" onclick="openLiveFile()">&#128194; Log-Datei &#246;ffnen (Live)</button>
      <button class="btn btn-danger" id="stop-btn" onclick="stopLive()" style="display:none">&#9209; Stopp</button>
      <div class="live-indicator" id="live-indicator" style="display:none"><div class="live-dot"></div> LIVE &middot; 1s Poll</div>
      <span id="live-file-name" style="font-size:12px;color:var(--text-dim)"></span>
    </div>
    <div id="live-fsapi-hint" style="display:none;margin-bottom:10px;padding:8px 14px;background:var(--bg-panel);border:1px solid var(--border-lit);border-radius:8px;font-size:12px;color:var(--text-sec)">
      &#9888; Kein File System API Support. Empfohlen: Chrome/Edge.
    </div>
    <div id="live-progress" style="display:none">
      <div class="progress-wrap">
        <div class="progress-header"><span class="progress-label" id="live-progress-label">Lese...</span><span class="progress-pct" id="live-progress-pct">0%</span></div>
        <div class="progress-bar-track"><div class="progress-bar-fill" id="live-progress-bar" style="width:0%"></div></div>
        <div class="progress-stats" id="live-progress-stats"></div>
      </div>
    </div>
    <div class="grid-4 section">
      <div class="stat-box"><div class="stat-label">Letzter Pull</div><div class="stat-value gold" id="stat-pull-num">&#8212;</div><div class="stat-sub" id="stat-boss-name">Kein Pull</div></div>
      <div class="stat-box"><div class="stat-label">Pull-Dauer</div><div class="stat-value" id="stat-duration">&#8212;</div><div class="stat-sub" id="stat-status-badge"></div></div>
      <div class="stat-box"><div class="stat-label">Tode (akt. Pull)</div><div class="stat-value red" id="stat-deaths-current">0</div><div class="stat-sub">Spieler gestorben</div></div>
      <div class="stat-box"><div class="stat-label">Pulls geladen</div><div class="stat-value" id="stat-pulls-total">0</div><div class="stat-sub" id="stat-deaths-total">0 Tode gesamt</div></div>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="card-title">&#128128; Tode &#8212; Letzter Pull</div>
        <div class="scroll-area" id="live-deaths-list"><div class="empty"><div class="empty-icon">&#128737;</div><p>Noch keine Tode</p></div></div>
      </div>
      <div class="card">
        <div class="card-title">&#128203; Pull-Timeline</div>
        <div class="scroll-area" id="live-timeline"><div class="empty"><div class="empty-icon">&#9201;</div><p>Warte auf Pull...</p></div></div>
      </div>
    </div>
  </div>
  <hr class="divider">
  <div class="section">
    <div class="flex-gap" style="margin-bottom:10px">
      <div class="card-title" style="margin-bottom:0;flex:1">&#128220; Pull-History (Session)</div>
      <label class="ctrl-label">Tode ignorieren ab:</label>
      <input type="number" class="num-input" id="live-death-limit" value="0" min="0" max="99" onchange="renderLiveHistory()">
      <span class="ctrl-label">Tod(e)</span>
    </div>
    <div class="pull-row pull-row-header"><span>#</span><span>Boss</span><span>Dauer</span><span>Tode</span><span>Ergebnis</span></div>
    <div class="scroll-area" id="live-pull-history" style="max-height:280px"><div class="empty"><p>Keine Pulls</p></div></div>
    <div id="live-pull-detail" style="display:none" class="detail-panel"></div>
  </div>
</div>

<!-- ANALYSE -->
<div id="view-analysis" class="view">
  <div class="section">
    <div class="flex-gap" style="margin-bottom:12px">
      <button class="btn btn-primary" id="an-open-btn" onclick="openAnalysisFiles()">&#128194; Log-Dateien hinzuf&#252;gen</button>
      <button class="btn" onclick="clearAnalysis()">&#128465; Zur&#252;cksetzen</button>
      <select class="boss-select" id="boss-filter" onchange="filterBoss()"><option value="">&#8212; Alle Bosse &#8212;</option></select>
      <label class="ctrl-label" style="margin-left:6px">Tode ignorieren ab:</label>
      <input type="number" class="num-input" id="death-limit" value="0" min="0" max="99" onchange="filterBoss()">
      <span class="ctrl-label">Tod(e)</span>
    </div>
    <div id="an-progress" style="display:none">
      <div class="progress-wrap">
        <div class="progress-header"><span class="progress-label" id="an-progress-label">Verarbeite...</span><span class="progress-pct" id="an-progress-pct">0%</span></div>
        <div class="progress-bar-track"><div class="progress-bar-fill" id="an-progress-bar" style="width:0%"></div></div>
        <div class="progress-stats" id="an-progress-stats"></div>
      </div>
    </div>
    <div class="file-chips" id="analysis-files-list"></div>
  </div>
  <div class="grid-4 section">
    <div class="stat-box"><div class="stat-label">Gesamt-Pulls</div><div class="stat-value gold" id="an-total-pulls">0</div><div class="stat-sub" id="an-date-range">&#8212;</div></div>
    <div class="stat-box"><div class="stat-label">Kills</div><div class="stat-value green" id="an-kills">0</div><div class="stat-sub" id="an-kill-rate">Kill-Rate &#8212;</div></div>
    <div class="stat-box"><div class="stat-label">&#216; Pull-Dauer</div><div class="stat-value" id="an-avg-duration">&#8212;</div><div class="stat-sub">Schnitt aller Pulls</div></div>
    <div class="stat-box"><div class="stat-label">Gefilterte Tode</div><div class="stat-value red" id="an-total-deaths">0</div><div class="stat-sub" id="an-deaths-per-pull">&#216; &#8212; / Pull</div></div>
  </div>
  <div class="grid-2 section">
    <div class="card">
      <div class="card-title" id="an-deaths-by-player-title">&#128128; Tode pro Spieler</div>
      <div id="an-deaths-by-player"><div class="empty"><div class="empty-icon">&#128194;</div><p>Keine Logs geladen</p></div></div>
    </div>
    <div class="card">
      <div class="card-title" id="an-death-causes-title">&#9888; H&#228;ufigste Todesursachen</div>
      <div id="an-death-causes"><div class="empty"><div class="empty-icon">&#128194;</div><p>Keine Logs geladen</p></div></div>
    </div>
  </div>
  <div class="card section">
    <div class="card-title">&#128200; Pull-Dauer Verlauf <span style="font-size:10px;font-weight:400;color:var(--text-dim);text-transform:none;letter-spacing:0">&nbsp;&#183; Klick auf Balken = Pull-Detail</span></div>
    <div id="an-duration-chart"><div class="empty"><div class="empty-icon">&#128194;</div><p>Keine Logs geladen</p></div></div>
