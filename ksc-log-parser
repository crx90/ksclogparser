// ── RAID CD TIMELINE ─────────────────────────────────────────────
const CD_CAT_ORDER = ['major','minor','consumable'];

function buildRaidCDHTML(pull) {
  if (!pull.raidCDs || pull.raidCDs.length === 0) return '';
  const raidSet = getRaidCDSet();
  const rawCDs = pull.raidCDs.filter(cd => raidSet.has(cd.spell));
  if (rawCDs.length === 0) return '';

  const pullDurMs = pull.endTime - pull.startTime;
  if (!pullDurMs || pullDurMs <= 0) return '';

  // Worker already deduplicates by SPELL_CAST_SUCCESS (real casts only)
  // Small client-side safety dedup for any remaining log duplicates
  const deduped = [];
  for (const cd of rawCDs.sort((a,b) => a.offsetMs - b.offsetMs)) {
    const key = cd.spell + '|' + (cd.caster||'');
    const last = [...deduped].reverse().find(d => (d.spell+'|'+(d.caster||'')) === key);
    if (!last || (cd.offsetMs - last.offsetMs) > 1000) {
      deduped.push(cd);
    }
  }

  // Group by spell
  const bySpell = {};
  for (const cd of deduped) {
    if (!bySpell[cd.spell]) bySpell[cd.spell] = { entries:[], spellId: cd.spellId||null };
    bySpell[cd.spell].entries.push(cd);
  }
  const spells = Object.keys(bySpell).sort((a,b) => a.localeCompare(b));
  if (!spells.length) return '';

  // Layout: fixed left label col + timeline
  const ROW_H = 32, PAD_L = 140, PAD_R = 12, PAD_T = 8, PAD_B = 24;
  const W = 700;
  const trackW = W - PAD_L - PAD_R;
  const H = spells.length * ROW_H + PAD_T + PAD_B;
  const tx = ms => PAD_L + Math.max(0, Math.min(1, ms / pullDurMs)) * trackW;

  let svg = '<svg viewBox="0 0 '+W+' '+H+'" width="100%" style="display:block;background:var(--bg-deep);border-radius:6px">';

  // Grid lines + time labels
  const tickStep = pullDurMs > 180000 ? 60000 : pullDurMs > 60000 ? 30000 : 15000;
  for (let ms = 0; ms <= pullDurMs; ms += tickStep) {
    const x = tx(ms).toFixed(1);
    svg += '<line x1="'+x+'" y1="'+PAD_T+'" x2="'+x+'" y2="'+(H-PAD_B)+'" stroke="#1e2530" stroke-width="1"/>';
    svg += '<text x="'+x+'" y="'+(H-6)+'" text-anchor="middle" font-size="9" fill="#4a5568">'+formatDuration(ms)+'</text>';
  }

  // Death markers
  if (pull.deaths) {
    for (const d of pull.deaths) {
      const x = tx(d.offsetMs).toFixed(1);
      svg += '<line x1="'+x+'" y1="'+PAD_T+'" x2="'+x+'" y2="'+(H-PAD_B)+'" stroke="rgba(192,57,43,0.25)" stroke-width="1" stroke-dasharray="3,2"/>';
      svg += '<text x="'+x+'" y="'+(PAD_T+10)+'" font-size="7" fill="rgba(192,57,43,0.5)" text-anchor="middle">&#9760;</text>';
    }
  }

  // Separator between label col and timeline
  svg += '<line x1="'+PAD_L+'" y1="'+PAD_T+'" x2="'+PAD_L+'" y2="'+(H-PAD_B)+'" stroke="#252b36" stroke-width="1"/>';

  // Rows
  spells.forEach((spell, idx) => {
    const { entries, spellId } = bySpell[spell];
    const y = PAD_T + idx * ROW_H;
    const midY = y + ROW_H / 2;

    // Alternating row bg
    if (idx % 2 === 0) svg += '<rect x="0" y="'+y+'" width="'+W+'" height="'+ROW_H+'" fill="rgba(255,255,255,0.012)"/>';

    // Row bottom separator
    svg += '<line x1="0" y1="'+(y+ROW_H)+'" x2="'+W+'" y2="'+(y+ROW_H)+'" stroke="#1a1f28" stroke-width="0.5"/>';

    // Spell name label in SVG (perfectly aligned) + invisible HTML anchor for Wowhead tooltip
    svg += '<text x="'+(PAD_L-8)+'" y="'+(midY+4)+'" text-anchor="end" font-size="12" fill="#c8a84b" font-weight="600" style="pointer-events:none">'+escHtml(spell)+'</text>';

    // Group entries by caster for color variation (all same spell, different casters)
    const casterColors = {};
    const uniqueCasters = [...new Set(entries.map(e => e.caster ? e.caster.split('-')[0] : '?'))];
    uniqueCasters.forEach((c, ci) => { casterColors[c] = ci; });
    // Shades of gold for multiple casters of same spell
    const shades = ['#c8a84b','#e8c870','#a08030','#f0d890'];

    // Track last label x per caster to avoid overlap
    const lastLabelX = {};

    entries.forEach(entry => {
      const x = tx(entry.offsetMs);
      const casterShort = entry.caster ? entry.caster.split('-')[0] : '?';
      const col = shades[casterColors[casterShort] % shades.length];

      // Vertical line — full row height
      svg += '<line x1="'+x.toFixed(1)+'" y1="'+(y+2)+'" x2="'+x.toFixed(1)+'" y2="'+(y+ROW_H-2)+'" stroke="'+col+'" stroke-width="2" stroke-linecap="round">';
      svg += '<title>'+escHtml(spell)+' — '+escHtml(casterShort)+' @ '+formatDuration(entry.offsetMs)+'</title>';
      svg += '</line>';

      // Caster label: show only if far enough from last label for this caster
      const MIN_LABEL_GAP = 60; // px
      const prevX = lastLabelX[casterShort];
      if (!prevX || (x - prevX) >= MIN_LABEL_GAP) {
        const labelX = Math.min(x + 3, W - PAD_R - 2);
        svg += '<text x="'+labelX.toFixed(1)+'" y="'+(midY+4)+'" font-size="9" fill="'+col+'" style="pointer-events:none">'+escHtml(casterShort)+'</text>';
        lastLabelX[casterShort] = x;
      }
    });
  });

  svg += '</svg>';

  // Invisible HTML anchors for Wowhead tooltips — positioned over the SVG label area
  // The SVG renders as a % width, so we use a padding-top trick to match SVG row positions
  const svgAspect = H / W; // height/width ratio of the SVG viewBox
  const linkDiv = '<div style="position:absolute;left:0;top:0;width:'+PAD_L+'px;height:100%;pointer-events:none">'
    + spells.map((spell, idx) => {
        // Position as % of SVG height to stay in sync regardless of rendered size
        const topPct = ((PAD_T + idx * ROW_H + ROW_H/2 - 8) / H * 100).toFixed(2);
        return '<div style="position:absolute;right:0;top:'+topPct+'%;pointer-events:auto">'
          + spellLink(spell,'rcd-spell-link rcd-invisible-link',bySpell[spell].spellId) + '</div>';
      }).join('')
    + '</div>';

  return '<div style="margin-top:14px">'
    + '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-sec);margin-bottom:8px">'
    + '&#128737; Raid Cooldowns'
    + '<span style="font-weight:400;color:var(--text-dim);text-transform:none;letter-spacing:0;margin-left:8px">'
    + deduped.length + ' Einsätze &nbsp;&#183;&nbsp; Hover für Details</span>'
    + '</div>'
    + '<div style="position:relative;overflow:hidden">'+linkDiv+svg+'</div>'
    + '</div>';
}

// ── DEATH CONTEXT RENDERER ──────────────────────────────────────
function renderDeathContext(death,pull,containerEl){
  if(!death||!death.context||death.context.length===0){
    containerEl.innerHTML='<div style="margin-top:14px;padding:10px;background:var(--bg-deep);border-radius:8px;font-size:13px;color:var(--text-dim)">Keine Context-Events vorhanden.</div>';
    return;
  }
  const deathTs=pull.startTime+death.offsetMs;
  const windowMs=5000;
  const startTs=deathTs-windowMs;
  const pullStartTime=pull.startTime;
  // Sort + strictly clamp: only events within [startTs, deathTs] — no events after death
  const sortedCtx=[...death.context]
    .filter(e => e.ts >= startTs && e.ts <= deathTs)
    .sort((a,b)=>a.ts-b.ts);
  const hpEvents=sortedCtx.filter(e=>e.maxHP>0&&(e.type==='dmg'||e.type==='heal'));
  const cdEvents=sortedCtx.filter(e=>e.type==='cd');
  const W=560,H=120,PAD={l:36,r:12,t:10,b:28};
  const gW=W-PAD.l-PAD.r,gH=H-PAD.t-PAD.b;
  const tx=ts=>PAD.l+Math.max(0,Math.min(1,(ts-startTs)/windowMs))*gW;
  const ty=pct=>PAD.t+(1-Math.max(0,Math.min(1,pct)))*gH;
  let svgLines='',svgMarkers='',svgCDs='',svgLabels='';
  const snapshots=hpEvents.map(e=>({ts:e.ts,pct:e.maxHP>0?e.currentHP/e.maxHP:0,type:e.type,spell:e.spell,amount:e.amount}));
  // snapshots already sorted because hpEvents comes from sortedCtx
  let points=[tx(startTs)+','+ty(1)];
  for(const s of snapshots){
    const x=tx(s.ts).toFixed(1),y=ty(s.pct).toFixed(1);
    points.push(x+','+y);
