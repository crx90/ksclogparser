let aplSelectedPull = null;

// ── APL Parser ────────────────────────────────────────────────────
function parseAPL(text) {
  const lines = text.split('\n').map(l=>l.trim()).filter(l=>l&&!l.startsWith('#'));
  const lists = {}; // listName → [{spell, displayName, ifCond, raw, params}]

  for (const line of lines) {
    const m = line.match(/^actions(?:\.(\w+))?\+?=\/?(.*)/);
    if (!m) continue;
    const listName = m[1] || '__main__';
    const rest = m[2].trim();
    if (!rest) continue;

    // Split spell name from params (first comma not inside parens)
    let depth=0, commaAt=-1;
    for(let i=0;i<rest.length;i++){
      if(rest[i]==='(')depth++;
      else if(rest[i]==')')depth--;
      else if(rest[i]===','&&depth===0){commaAt=i;break;}
    }
    const spellSimc = commaAt===-1?rest:rest.slice(0,commaAt);
    const paramsStr = commaAt===-1?'':rest.slice(commaAt+1);

    // Parse params (key=value pairs)
    const params = {};
    let pd=0, pkey='', pval='', inkey=true;
    for(let i=0;i<=paramsStr.length;i++){
      const c=i<paramsStr.length?paramsStr[i]:',';
      if(c==='(')pd++;
      else if(c===')')pd--;
      else if(c==='='&&inkey&&pd===0){inkey=false;continue;}
      else if(c===','&&pd===0){
        if(pkey) params[pkey.trim()]=pval.trim();
        pkey='';pval='';inkey=true;continue;
      }
      if(inkey)pkey+=c; else pval+=c;
    }

    if (!lists[listName]) lists[listName] = [];
    lists[listName].push({
      spell: spellSimc.trim(),
      displayName: simcToDisplayName(spellSimc.trim()),
      ifCond: params.if || null,
      name: params.name || null,  // for call_action_list/run_action_list
      raw: line,
      params,
    });
  }

  return { lists };
}

// ── Buff Tracker ─────────────────────────────────────────────────
// Rebuilds active buffs at each cast timestamp from pull.buffEvents
function buildBuffStateAtTime(pull, playerName, targetTs) {
  const buffs = {}; // buffKey → {name, stack, appliedAt, expireAt}
  if (!pull.buffEvents) return buffs;

  const playerNorm = normalizeForMatch(playerName.split('-')[0]);

  for (const ev of pull.buffEvents) {
    if (ev.ts > targetTs) break;
    const destNorm = normalizeForMatch((ev.destName||'').split('-')[0]);
    if (destNorm !== playerNorm) continue;

    const key = normalizeForMatch(ev.spell);
    if (ev.type === 'applied') {
      buffs[key] = { name: ev.spell, stack: ev.stack||1, appliedAt: ev.ts };
    } else if (ev.type === 'stacked' && buffs[key]) {
      buffs[key].stack = ev.stack||((buffs[key].stack||1)+1);
    } else if (ev.type === 'removed') {
      delete buffs[key];
    }
  }
  return buffs;
}

// ── APL Rule Evaluator ────────────────────────────────────────────
// Given a cast and the buffs active at that time, check if APL conditions
// for earlier (higher-priority) actions would have been met.
// Returns a list of "should have cast X instead" suggestions.

function evaluateAPLAtCast(cast, buffs, runicPower, apl, pullDurMs) {
  if (!apl) return [];
  const suggestions = [];
  const castNorm = normalizeForMatch(cast.spell);
  const offsetSec = cast.offsetMs / 1000;
  const fightRemains = Math.max(0, pullDurMs/1000 - offsetSec);

  // Find the action list entry for this cast
  let castListName = null, castIdx = -1;
  for (const [lname, actions] of Object.entries(apl.lists)) {
    const idx = actions.findIndex(a => normalizeForMatch(a.displayName||'') === castNorm
      || normalizeForMatch(a.spell) === castNorm);
    if (idx !== -1 && (castIdx === -1 || idx < castIdx)) {
      castListName = lname; castIdx = idx;
    }
  }

  if (castListName === null) return []; // spell not in APL, skip

  // Check if any higher-priority action in same list could have been cast
  const list = apl.lists[castListName] || [];
  for (let i = 0; i < castIdx; i++) {
    const action = list[i];
    if (!action.displayName) continue; // skip meta-actions
    if (['call_action_list','run_action_list','auto_attack','use_items','use_item','potion','variable','snapshot_stats'].includes(action.spell)) continue;

    const condResult = tryEvalCondition(action.ifCond, buffs, runicPower, offsetSec, fightRemains);
    if (condResult === true) {
      suggestions.push({
        spell: action.displayName,
        simcSpell: action.spell,
        priority: i,
        condition: action.ifCond,
        reason: `APL Priorität ${i+1} hätte '${action.displayName}' bevorzugt`,
      });
    }
  }
  return suggestions;
}

function tryEvalCondition(cond, buffs, runicPower, timeSec, fightRemains) {
  if (!cond) return true; // no condition = always castable

  // Replace known values
  let c = cond
    .replace(/\btime\b/g, String(timeSec.toFixed(1)))
    .replace(/\bfight_remains\b/g, String(fightRemains.toFixed(1)))
    .replace(/\bgcd\b/g, '1.5')
    .replace(/\brunic_power\.deficit\b/g, runicPower!==null?String(120-runicPower):'?')
    .replace(/\brunic_power\b/g, runicPower!==null?String(runicPower):'?');

  // Replace buff.X.up / buff.X.down / buff.X.stack / buff.X.remains
  c = c.replace(/buff\.(\w+)\.(up|down|stack|remains|react)/g, (_, name, prop) => {
    const key = normalizeForMatch(name);
    const b = buffs[key];
    if (prop==='up') return b?'1':'0';
    if (prop==='down'||prop==='react') return b?'0':'1';
    if (prop==='stack') return b?String(b.stack||1):'0';
    if (prop==='remains') return '?'; // can't know duration
    return '?';
  });

  // Replace debuff.X.up
  c = c.replace(/debuff\.(\w+)\.(up|down)/g, '?');

  // Replace !buff.X.up → simplified
  c = c.replace(/!(\d)/g, (_, d) => d==='1'?'0':'1');

  // If any ? remains, we can't fully evaluate → return null (unknown)
  if (c.includes('?')) return null;

  // Eval simple boolean expression
  try {
    // Replace & and | carefully (not inside numbers)
    const expr = c
      .replace(/\&\&/g,'&&').replace(/\|\|/g,'||')
      .replace(/(?<![&|])&(?![&])/g,'&&')
      .replace(/(?<![|])\|(?![|])/g,'||')
      .replace(/(?<!\!|>|<|=)=(?!=)/g,'===');
    // eslint-disable-next-line no-new-func
    return !!Function('"use strict";return ('+expr+')')();
  } catch(e) {
    return null;
  }
}

