let analysisFileMeta=[],analysisPulls=[];
let selectedPullNum=null,selectedDeathIdx=null,selectedPlayer=null;

function openAnalysisFiles(){document.getElementById('analysis-file-input').click();}
async function handleAnalysisFiles(evt) {
  const files=Array.from(evt.target.files);
