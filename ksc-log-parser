async function doLiveScan() {
  if (liveLoading) return;
  liveLoading = true;
  document.getElementById('live-progress').style.display='block';
  document.getElementById('live-open-btn').disabled=true;
  const worker = createWorker();
  liveWorker = worker;
  worker.onmessage = (e) => {
    if (e.data.type==='progress') {
      const {pct,bytesProcessed,linesProcessed,pullsFound} = e.data;
      document.getElementById('live-progress-pct').textContent=pct+'%';
      document.getElementById('live-progress-bar').style.width=pct+'%';
      document.getElementById('live-progress-stats').textContent=
        formatBytes(bytesProcessed)+' · '+linesProcessed.toLocaleString()+' Zeilen · '+pullsFound+' Pulls';
    } else if (e.data.type==='done') {
      const pulls = e.data.pulls;
      pulls.forEach((p,i)=>p.num=i+1);
      livePulls=pulls; livePullCounter=pulls.length; liveOffset=liveFile.size;
      const lastP=pulls[pulls.length-1];
      if (lastP?.inProgress) liveParseState.currentPull=lastP;
      liveLoading=false;
      document.getElementById('live-progress').style.display='none';
      document.getElementById('live-open-btn').disabled=false;
      worker.terminate(); renderLive();
    }
  };
  await streamFileToWorker(liveFile, worker);
}
async function doLivePoll() {
  if (liveLoading||!liveFile) return;
  try {
    if (liveFileHandle) liveFile = await liveFileHandle.getFile();
    const newSize = liveFile.size;
    if (newSize<=liveOffset) return;
    const text = await liveFile.slice(liveOffset, newSize).text();
    liveOffset=newSize;
    if (!text.trim()) return;
    deltaParseLines(text.split('\n'));
    renderLive();
  } catch(e) { console.warn('poll error:',e); }
}

function deltaParseLines(lines) {
  const state = liveParseState;
  const DEATH_CTX = 5000;
  const cdMap = getCooldownMap();
  const RELEVANT = new Set(['ENCOUNTER_START','ENCOUNTER_END','UNIT_DIED',
    'SPELL_DAMAGE','SPELL_PERIODIC_DAMAGE','RANGE_DAMAGE','SWING_DAMAGE',
    'ENVIRONMENTAL_DAMAGE','SPELL_INSTAKILL','SPELL_HEAL','SPELL_PERIODIC_HEAL','SPELL_AURA_APPLIED']);
  for (const rawLine of lines) {
    const line = rawLine.trim(); if (!line) continue;
    if (line.indexOf('ENCOUNTER_')===-1 && line.indexOf('UNIT_DIED')===-1 &&
        line.indexOf('_DAMAGE')===-1 && line.indexOf('INSTAKILL')===-1 &&
        line.indexOf('_HEAL')===-1 && line.indexOf('AURA_APPLIED')===-1) continue;
    const si=line.indexOf('  '); if(si===-1) continue;
    const ts=parseTimestampUI(line.substring(0,si)); if(!ts) continue;
    const rest=line.substring(si+2);
    const ci=rest.indexOf(',');
    const ev=ci===-1?rest:rest.substring(0,ci);
    if(!RELEVANT.has(ev)) continue;
    const parts=splitCSVUI(rest);
    if(ev==='ENCOUNTER_START') {
      if(state.currentPull){state.currentPull.endTime=ts;state.currentPull.success=false;mergeLivePull({...state.currentPull});}
      state.currentPull={bossName:parts[2],startTime:ts,endTime:null,success:false,deaths:[],
        events:[{type:'start',offsetMs:0,text:'Pull gestartet',detail:parts[2]}]};
    } else if(ev==='ENCOUNTER_END'&&state.currentPull) {
      state.currentPull.endTime=ts; state.currentPull.success=parts[5]==='1';
      state.currentPull.events.push({type:state.currentPull.success?'end-kill':'end-wipe',
        offsetMs:ts-state.currentPull.startTime,text:state.currentPull.success?'Boss besiegt':'Wipe',
        detail:formatDuration(ts-state.currentPull.startTime)});
      mergeLivePull({...state.currentPull}); state.currentPull=null;
    } else if(ev==='UNIT_DIED') {
      const dg=parts[5],dn=parts[6];
      if(dg&&dg.startsWith('Player-')){
        const c=state.lastDamageTaken[dg];
        const ctx=state.contextBuffer[dg]?[...state.contextBuffer[dg]]:[];
        const d={name:dn,guid:dg,offsetMs:state.currentPull?ts-state.currentPull.startTime:0,
          cause:c?c.spell:'Unbekannt',causeBy:c?c.srcName:'',context:ctx};
        if(state.currentPull){state.currentPull.deaths.push(d);
          state.currentPull.events.push({type:'death',offsetMs:ts-state.currentPull.startTime,text:dn+' gestorben',detail:c?c.spell:''});}
      }
    } else if(ev==='SPELL_AURA_APPLIED') {
      const dg=parts[5],sn=parts[10];
      if(dg&&dg.startsWith('Player-')&&sn&&cdMap.has(sn)){
        const cat=cdMap.get(sn);
        if(!state.contextBuffer[dg]) state.contextBuffer[dg]=[];
        state.contextBuffer[dg].push({ts,type:'cd',srcName:parts[2],spell:sn,amount:0,currentHP:0,maxHP:0,cdCat:cat});
        pruneCtx(state.contextBuffer[dg],ts,DEATH_CTX);
      }
    } else {
      const dg=parts[5],sn=parts[10]||(ev==='SWING_DAMAGE'?'Melee':'?'),src=parts[2];
      const amount=parseInt(parts[31])||0,curHP=parseInt(parts[14])||0,maxHP=parseInt(parts[15])||0;
      const isDmg=ev!=='SPELL_HEAL'&&ev!=='SPELL_PERIODIC_HEAL';
      if(dg){
        if(isDmg) state.lastDamageTaken[dg]={spell:sn,srcName:src};
        if(dg.startsWith('Player-')){
          if(!state.contextBuffer[dg]) state.contextBuffer[dg]=[];
          state.contextBuffer[dg].push({ts,type:isDmg?'dmg':'heal',srcName:src,spell:sn,amount,currentHP:curHP,maxHP});
          pruneCtx(state.contextBuffer[dg],ts,DEATH_CTX);
        }
      }
    }
  }
  if(state.currentPull) mergeLivePull({...state.currentPull,inProgress:true});
}

function pruneCtx(buf, now, window) {
  const cutoff=now-window; let i=0;
  while(i<buf.length&&buf[i].ts<cutoff) i++;
  if(i>0) buf.splice(0,i);
}
function mergeLivePull(p) {
  const idx=livePulls.findIndex(x=>x.startTime===p.startTime&&x.bossName===p.bossName);
  if(idx>=0) livePulls[idx]={...p,num:livePulls[idx].num};
  else { livePullCounter++; livePulls.push({...p,num:livePullCounter}); }
}
function stopLive() {
  clearInterval(liveInterval); liveInterval=null;
  clearInterval(liveTimerInterval); liveTimerInterval=null;
  if(liveWorker){liveWorker.terminate();liveWorker=null;}
  document.getElementById('live-indicator').style.display='none';
  document.getElementById('stop-btn').style.display='none';
  document.getElementById('live-progress').style.display='none';
  document.getElementById('live-open-btn').disabled=false;
  liveLoading=false;
}
function parseTimestampUI(str) {
  const m=str.match(/(\d+)\/(\d+)\/(\d+)\s+(\d+):(\d+):(\d+)\.(\d+)/);
  if(!m) return 0;
  const[,mo,dy,yr,hh,mm,ss,ms]=m.map(Number);
  return Date.UTC(yr,mo-1,dy,hh,mm,ss,ms);
}
function splitCSVUI(line) {
  const out=[];let cur='';let inQ=false;
  for(let i=0;i<line.length;i++){const c=line[i];if(c==='"'){inQ=!inQ;}else if(c===','&&!inQ){out.push(cur);cur='';continue;}if(c!=='"')cur+=c;else cur+=c;}
  out.push(cur); return out.map(s=>s.replace(/^"(.*)"$/,'$1'));
}

