// ── WOWHEAD TOOLTIPS ────────────────────────────────────────────
// Config + script in <head>. Tooltips require numeric spell IDs.
// We resolve name→ID via nether.wowhead.com API, cache in localStorage.

function rehintWowhead() {
  if (window.WH && WH.Tooltip && WH.Tooltip.init) WH.Tooltip.init();
}

// Persistent cache: spell name → {id, icon} stored in localStorage
const SPELL_CACHE_KEY = 'wow_parser_spell_cache_v1';
let spellCache = {};
(function loadSpellCache() {
  try { spellCache = JSON.parse(localStorage.getItem(SPELL_CACHE_KEY) || '{}'); } catch(e) { spellCache = {}; }
})();
function saveSpellCache() {
  try { localStorage.setItem(SPELL_CACHE_KEY, JSON.stringify(spellCache)); } catch(e) {}
}

// In-flight requests to avoid duplicate fetches
const spellFetching = {};

async function resolveSpell(name) {
  if (spellCache[name] !== undefined) return spellCache[name]; // null = not found
  if (spellFetching[name]) return spellFetching[name];
  const slug = spellSlug(name);
  const promise = fetch('https://nether.wowhead.com/tooltip/spell/' + slug + '?dataEnv=4&locale=0')
    .then(r => r.ok ? r.json() : null)
    .then(d => {
      const result = d && d.id ? { id: d.id, icon: d.icon || null } : null;
      spellCache[name] = result;
      saveSpellCache();
      delete spellFetching[name];
      return result;
    })
    .catch(() => { spellCache[name] = null; delete spellFetching[name]; return null; });
  spellFetching[name] = promise;
  return promise;
}

// Enrich all .wh-spell links in a container:
// - fetch ID via API
// - update data-wowhead="spell=ID" so Wowhead tooltip script works
// - prepend spell icon
async function enrichSpellLinks(containerEl) {
  if (!containerEl) return;
  const links = Array.from(containerEl.querySelectorAll('a.wh-spell:not([data-enriched])'));
  if (!links.length) { rehintWowhead(); return; }

  await Promise.all(links.map(async a => {
    a.dataset.enriched = '1';
    const name = a.dataset.spellname;
    if (!name) return;
    const info = await resolveSpell(name);
    if (!info) return;
    // CRITICAL: set data-wowhead with numeric ID ONLY — slug does not work for tooltips
    a.href = 'https://www.wowhead.com/spell=' + info.id;
    a.dataset.wowhead = 'spell=' + info.id;
    // Prepend icon from zamimg
    if (info.icon) {
      if (!a.querySelector('img')) {
        const img = document.createElement('img');
        img.src = 'https://wow.zamimg.com/images/wow/icons/small/' + info.icon + '.jpg';
        img.width = 15; img.height = 15;
        img.style.cssText = 'border-radius:2px;margin-right:4px;vertical-align:middle;flex-shrink:0;image-rendering:crisp-edges;position:relative;top:-1px';
        img.onerror = () => img.remove();
        a.prepend(img);
      }
    }
  }));
  // Only call init AFTER all IDs are set — Wowhead tooltip script reads data-wowhead on init
  rehintWowhead();
}

function spellSlug(name) {
  return name.toLowerCase().replace(/['']/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
}

// Render a spell link — uses numeric ID immediately if known, enriched async otherwise
function spellLink(name, cssClass, spellId) {
  if (!name || name === 'Melee' || name === 'Unbekannt' || name === 'Umwelt') {
    return '<span class="' + (cssClass||'') + '">' + escHtml(name) + '</span>';
  }
  const numericId = spellId && /^\d+$/.test(String(spellId)) && String(spellId) !== '0' ? String(spellId) : null;
  // If we already know the numeric ID, use it directly — no enrichment needed
  if (numericId) {
    const cached = spellCache[name];
    // Store in cache so icon can be added
    if (!cached) spellCache[name] = { id: parseInt(numericId), icon: null };
    return '<a href="https://www.wowhead.com/spell=' + numericId
      + '" class="wh-spell ' + (cssClass||'') + '"'
      + ' data-spellname="' + escHtml(name) + '"'
      + ' data-wowhead="spell=' + numericId + '"'
      + ' target="_blank" rel="noopener">' + escHtml(name) + '</a>';
  }
  // Fallback: slug href, enriched async
  const slug = spellSlug(name);
  return '<a href="https://www.wowhead.com/spell=' + slug
    + '" class="wh-spell ' + (cssClass||'') + '"'
    + ' data-spellname="' + escHtml(name) + '"'
    + ' target="_blank" rel="noopener">' + escHtml(name) + '</a>';
}

