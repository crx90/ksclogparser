<script id="worker-src" type="text/plain">
const DEATH_CONTEXT_WINDOW = 5000;

// Personal defensive CDs (tracked in death recap per-player)
const DEFAULT_COOLDOWNS = [
  ['Healthstone','consumable'],['Health Potion','consumable'],['Refreshing Healing Potion','consumable'],
  ['Cauterizing Shadows','consumable'],['Phial of Tepid Versatility','consumable'],
  ['Icebound Fortitude','major'],['Anti-Magic Shell','major'],['Lichborne','major'],
  ['Death Pact','major'],['Vampiric Blood','major'],
  ['Shield Wall','major'],['Die by the Sword','major'],['Spell Reflection','minor'],
  ['Ignore Pain','minor'],
  ['Divine Shield','major'],['Ardent Defender','major'],['Guardian of Ancient Kings','major'],
  ['Blessing of Protection','major'],['Lay on Hands','major'],
  ['Fortifying Brew','major'],['Zen Meditation','major'],['Diffuse Magic','major'],['Dampen Harm','major'],
  ['Barkskin','major'],['Survival Instincts','major'],['Frenzied Regeneration','minor'],
  ['Blur','major'],['Netherwalk','major'],['Metamorphosis','major'],
  ['Feint','minor'],['Evasion','major'],['Cloak of Shadows','major'],['Crimson Vial','minor'],
  ['Exhilaration','major'],['Survival of the Fittest','major'],
  ['Ice Block','major'],['Alter Time','minor'],['Prismatic Barrier','minor'],['Blazing Barrier','minor'],
  ['Unending Resolve','major'],['Dark Pact','major'],
  ['Astral Shift','major'],['Earth Elemental','major'],
  ['Dispersion','major'],['Fade','minor'],['Pain Suppression','major'],['Guardian Spirit','major'],
  ['Obsidian Scales','major'],['Renewing Blaze','major'],['Time Spiral','major'],
];

// Raid-wide CDs (affect multiple players — shown in pull CD timeline)
const DEFAULT_RAID_CDS = [
  'Anti-Magic Zone','Rallying Cry','Darkness','Power Word: Barrier',
  'Aura Mastery','Devotion Aura',
  'Revival','Restoral',
  'Tranquility',
  'Spirit Link Totem',
  'Mortal Coil',
  'Vampiric Embrace',
  'Darkness',
  'Smoke Bomb',
  'Barrier',
  'Unholy Ground',
];

let defCooldowns = new Map(DEFAULT_COOLDOWNS);
let raidCDSet = new Set(DEFAULT_RAID_CDS);

function parseTimestamp(str) {
  const m = str.match(/(\d+)\/(\d+)\/(\d+)\s+(\d+):(\d+):(\d+)\.(\d+)/);
  if (!m) return 0;
  const [,mo,dy,yr,hh,mm,ss,ms] = m.map(Number);
  return Date.UTC(yr,mo-1,dy,hh,mm,ss,ms);
}

function fastSplit(line) {
  const out = [];
  let start = 0, inQ = false;
  for (let i = 0; i < line.length; i++) {
    const c = line.charCodeAt(i);
    if (c === 34) { inQ = !inQ; }
    else if (c === 44 && !inQ) {
      out.push(line.slice(start, i).replace(/^"(.*)"$/, '$1'));
      start = i + 1;
    }
  }
  out.push(line.slice(start).replace(/^"(.*)"$/, '$1'));
  return out;
}

function formatDuration(ms) {
  if (!ms || ms <= 0) return '--';
  const s = Math.floor(ms/1000), m = Math.floor(s/60);
  return m > 0 ? m+'m '+String(s%60).padStart(2,'0')+'s' : s+'s';
}

let currentPull = null;
const lastDamageTaken = {};
const contextBuffer = {};
const pulls = [];
let lineBuffer = '';
let bytesProcessed = 0, totalBytes = 0, linesProcessed = 0;

const RELEVANT = new Set([
  'ENCOUNTER_START','ENCOUNTER_END','UNIT_DIED',
  'SPELL_DAMAGE','SPELL_PERIODIC_DAMAGE','RANGE_DAMAGE',
  'SWING_DAMAGE','ENVIRONMENTAL_DAMAGE','SPELL_INSTAKILL',
  'SPELL_HEAL','SPELL_PERIODIC_HEAL',
  'SPELL_AURA_APPLIED','SPELL_AURA_APPLIED_DOSE','SPELL_AURA_REMOVED',
  'SPELL_CAST_SUCCESS'
]);

function addToContext(destGUID, entry, now) {
  if (!destGUID) return;
  if (!contextBuffer[destGUID]) contextBuffer[destGUID] = [];
  contextBuffer[destGUID].push(entry);
  const cutoff = now - DEATH_CONTEXT_WINDOW;
  const buf = contextBuffer[destGUID];
  let i = 0;
  while (i < buf.length && buf[i].ts < cutoff) i++;
  if (i > 0) contextBuffer[destGUID] = buf.slice(i);
}

function processLine(line) {
  linesProcessed++;
  if (line.indexOf('ENCOUNTER_') === -1 && line.indexOf('UNIT_DIED') === -1 &&
      line.indexOf('_DAMAGE') === -1 && line.indexOf('INSTAKILL') === -1 &&
      line.indexOf('_HEAL') === -1 && line.indexOf('AURA_APPLIED') === -1 &&
      line.indexOf('AURA_REMOVED') === -1 && line.indexOf('CAST_SUCCESS') === -1) return;

  const spaceIdx = line.indexOf('  ');
  if (spaceIdx === -1) return;
  const tsStr = line.substring(0, spaceIdx);
  const rest = line.substring(spaceIdx + 2);
  const commaIdx = rest.indexOf(',');
  const event = commaIdx === -1 ? rest : rest.substring(0, commaIdx);
  if (!RELEVANT.has(event)) return;

  const timestamp = parseTimestamp(tsStr);
  if (!timestamp) return;
  const parts = fastSplit(rest);

  if (event === 'ENCOUNTER_START') {
    if (currentPull) { currentPull.endTime = timestamp; currentPull.success = false; pulls.push({...currentPull}); }
    currentPull = {
      encounterId: parts[1], bossName: parts[2], startTime: timestamp, endTime: null, success: false,
      deaths: [], events: [{ type:'start', offsetMs:0, text:'Pull gestartet', detail:parts[2] }],
      raidCDs: [],  // {offsetMs, caster, spell, spellId}
      playerCasts: [],  // {offsetMs, playerName, spell, spellId, runicPower}
      buffEvents: [],    // {ts, type, destName, spell, stack}
    };
  } else if (event === 'ENCOUNTER_END' && currentPull) {
    currentPull.endTime = timestamp;
    currentPull.success = parts[5] === '1';
    currentPull.events.push({
      type: currentPull.success ? 'end-kill' : 'end-wipe',
      offsetMs: timestamp - currentPull.startTime,
      text: currentPull.success ? 'Boss besiegt' : 'Wipe',
      detail: formatDuration(timestamp - currentPull.startTime),
    });
    pulls.push({...currentPull});
    currentPull = null;
  } else if (event === 'UNIT_DIED') {
    const destGUID = parts[5], destName = parts[6];
    if (destGUID && destGUID.startsWith('Player-')) {
      const c = lastDamageTaken[destGUID];
      const ctx = contextBuffer[destGUID] ? [...contextBuffer[destGUID]] : [];
      const death = {
        name: destName, guid: destGUID,
        offsetMs: currentPull ? timestamp - currentPull.startTime : 0,
        cause: c ? c.spell : 'Unbekannt', causeId: c ? c.spellId : null, causeBy: c ? c.srcName : '', context: ctx,
      };
      if (currentPull) {
        currentPull.deaths.push(death);
        currentPull.events.push({ type:'death', offsetMs: timestamp - currentPull.startTime,
          text: destName + ' gestorben', detail: c ? c.spell : '' });
      }
    }
  } else if (event === 'SPELL_AURA_APPLIED' || event === 'SPELL_AURA_APPLIED_DOSE') {
    const srcName = parts[2], srcGUID = parts[1], destGUID = parts[5], destName = parts[6], spellName = parts[10];
    // Track buff events for APL analysis
    if (currentPull && destGUID && destGUID.startsWith('Player-') && spellName) {
      const evType = event === 'SPELL_AURA_APPLIED_DOSE' ? 'stacked' : 'applied';
      currentPull.buffEvents.push({ ts:timestamp, type:evType, destName, spell:spellName, stack:parseInt(parts[12])||1 });
    }
    // Personal CD: track in per-player death context buffer
    const auraSpellId = parts[9];
    if (spellName && defCooldowns.has(spellName) && destGUID && destGUID.startsWith('Player-')) {
      const cat = defCooldowns.get(spellName);
      addToContext(destGUID, { ts:timestamp, type:'cd', srcName, spell:spellName, spellId:auraSpellId, amount:0, currentHP:0, maxHP:0, cdCat:cat }, timestamp);
    }
    // raidCDs are now tracked via SPELL_CAST_SUCCESS (more reliable caster info)
  } else if (event === 'SPELL_AURA_REMOVED') {
    const dg2=parts[5], sn2=parts[10];
    if (currentPull && dg2 && dg2.startsWith('Player-') && sn2)
      currentPull.buffEvents.push({ ts:timestamp, type:'removed', destName:parts[6], spell:sn2 });
  } else if (event === 'SPELL_CAST_SUCCESS') {
    // srcGUID must be a real player
    const srcGUID = parts[1], srcName = parts[2], spellId = parts[9], spellName = parts[10];
    const isRealPlayer = srcGUID && srcGUID.startsWith('Player-');
    if (isRealPlayer && currentPull) {
      const offs = timestamp - currentPull.startTime;
      // Track raid CDs
      if (spellName && raidCDSet.has(spellName)) {
        const isDup = currentPull.raidCDs.some(r =>
          r.spell === spellName && r.caster === srcName && Math.abs(r.offsetMs - offs) < 2000
        );
        if (!isDup) {
          currentPull.raidCDs.push({ offsetMs: offs, caster: srcName, spell: spellName, spellId });
        }
      }
      // Track ALL player casts for APL analysis
      // Extract runic power + runes from advanced log (parts[14]=currentHP ... we need resource fields)
      // Advanced log format after destGUID fields: unitHP,unitMaxHP,unitAttackPower,unitSpellPower,
      //   unitArmorReduction,unitFacing,X,Y,mapID,facing,level + resource1amount,resource1type,...
      // parts[12] onward for src unit info when src=dest
      const runicPower = parseInt(parts[17])||null;   // position varies, best effort
      currentPull.playerCasts.push({
        offsetMs: offs,
        playerName: srcName,
        spell: spellName,
        spellId,
        runicPower,
      });
    }
  } else if (event === 'SWING_DAMAGE') {
    const destGUID = parts[5], srcName = parts[2];
    if (destGUID) {
      lastDamageTaken[destGUID] = { spell:'Melee', srcName, spellId:null };
      if (destGUID.startsWith('Player-')) {
        const amount = parseInt(parts[31])||0, currentHP = parseInt(parts[14])||0, maxHP = parseInt(parts[15])||0;
        addToContext(destGUID, { ts:timestamp, type:'dmg', srcName, spell:'Melee', spellId:null, amount, currentHP, maxHP }, timestamp);
      }
    }
  } else if (event === 'ENVIRONMENTAL_DAMAGE') {
    const destGUID = parts[5], envType = parts[10]||'Umwelt';
    if (destGUID) {
      const envId = parts[9]||null;
      lastDamageTaken[destGUID] = { spell:envType, srcName:'Umgebung', spellId:envId };
      if (destGUID.startsWith('Player-')) {
        const amount = parseInt(parts[31])||0, currentHP = parseInt(parts[14])||0, maxHP = parseInt(parts[15])||0;
        addToContext(destGUID, { ts:timestamp, type:'dmg', srcName:'Umgebung', spell:envType, spellId:envId, amount, currentHP, maxHP }, timestamp);
      }
    }
  } else if (event === 'SPELL_HEAL' || event === 'SPELL_PERIODIC_HEAL') {
    const destGUID = parts[5];
    if (destGUID && destGUID.startsWith('Player-')) {
      const srcName = parts[2], spell = parts[10], spellId = parts[9];
      const amount = parseInt(parts[31])||0, currentHP = parseInt(parts[14])||0, maxHP = parseInt(parts[15])||0;
      addToContext(destGUID, { ts:timestamp, type:'heal', srcName, spell, spellId, amount, currentHP, maxHP }, timestamp);
    }
  } else {
    const destGUID = parts[5], spellName = parts[10], srcName = parts[2], spellId = parts[9];
    if (destGUID && spellName) {
      lastDamageTaken[destGUID] = { spell:spellName, srcName, spellId };
      if (destGUID.startsWith('Player-')) {
        const amount = parseInt(parts[31])||0, currentHP = parseInt(parts[14])||0, maxHP = parseInt(parts[15])||0;
        addToContext(destGUID, { ts:timestamp, type:'dmg', srcName, spell:spellName, spellId, amount, currentHP, maxHP }, timestamp);
      }
    }
  }
}

function processChunk(chunk) {
  lineBuffer += chunk;
  const lines = lineBuffer.split('\n');
  lineBuffer = lines.pop() || '';
  for (const line of lines) { if (line.trim()) processLine(line); }
}

function finalize() {
  if (lineBuffer.trim()) processLine(lineBuffer);
  if (currentPull) { currentPull.inProgress = true; pulls.push({...currentPull}); }
  return pulls;
}

self.onmessage = function(e) {
  const { type, data, fileSize, cooldowns } = e.data;
  if (type === 'start') {
    pulls.length = 0; currentPull = null; lineBuffer = '';
    bytesProcessed = 0; linesProcessed = 0; totalBytes = fileSize;
    Object.keys(lastDamageTaken).forEach(k => delete lastDamageTaken[k]);
    Object.keys(contextBuffer).forEach(k => delete contextBuffer[k]);
    if (cooldowns) defCooldowns = new Map(cooldowns);
    if (e.data.raidCDs) raidCDSet = new Set(e.data.raidCDs);
  } else if (type === 'chunk') {
    bytesProcessed += data.length;
    processChunk(data);
    const pct = totalBytes > 0 ? Math.round(bytesProcessed/totalBytes*100) : 0;
    self.postMessage({ type:'progress', pct, bytesProcessed, linesProcessed, pullsFound: pulls.length });
  } else if (type === 'end') {
    self.postMessage({ type:'done', pulls: finalize() });
  }
};

</script>
