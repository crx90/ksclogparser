  if (tab==='apl') renderAPLTab();
}

// ── STREAMING ────────────────────────────────────────────────────
const CHUNK_SIZE = 4*1024*1024;
async function streamFileToWorker(file, worker) {
  const totalSize = file.size;
  worker.postMessage({ type:'start', fileSize:totalSize, cooldowns:userCooldowns, raidCDs:userRaidCDs });
  let offset = 0;
  const decoder = new TextDecoder('utf-8');
  while (offset < totalSize) {
    const slice = file.slice(offset, offset+CHUNK_SIZE);
    const buffer = await slice.arrayBuffer();
    const text = decoder.decode(new Uint8Array(buffer), { stream: offset+CHUNK_SIZE < totalSize });
    worker.postMessage({ type:'chunk', data:text });
    offset += buffer.byteLength;
    await new Promise(r => setTimeout(r, 0));
  }
  worker.postMessage({ type:'end' });
}

