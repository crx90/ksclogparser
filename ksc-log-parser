        if(e.data.type==='progress'){
          const{pct,bytesProcessed,linesProcessed,pullsFound}=e.data;
          document.getElementById('an-progress-pct').textContent=pct+'%';
          document.getElementById('an-progress-bar').style.width=pct+'%';
          document.getElementById('an-progress-stats').textContent=formatBytes(bytesProcessed)+' · '+linesProcessed.toLocaleString()+' Zeilen · '+pullsFound+' Pulls';
        } else if(e.data.type==='done'){worker.terminate();resolve(e.data.pulls.filter(p=>!p.inProgress));}
      };
